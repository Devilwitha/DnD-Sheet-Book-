<InfoScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 15

        Label:
            text: "Systeminformationen"
            font_size: '30sp'
            size_hint_y: None
            height: 80
            bold: True

        BoxLayout:
            orientation: 'vertical'
            padding: 10
            spacing: 10
            size_hint_y: 1

            Label:
                id: raspberry_model
                text: "Raspberry Pi Modell: "
                font_size: '18sp'
                halign: 'left'
                valign: 'middle'
                text_size: self.width, None
                size_hint_y: None
                height: 50

            Label:
                id: os_version
                text: "Betriebssystem: "
                font_size: '18sp'
                halign: 'left'
                valign: 'middle'
                text_size: self.width, None
                size_hint_y: None
                height: 50

            Label:
                id: resolution
                text: "Auflösung: "
                font_size: '18sp'
                halign: 'left'
                valign: 'middle'
                text_size: self.width, None
                size_hint_y: None
                height: 50

            Label:
                id: folder_size
                text: "Größe des App-Ordners: "
                font_size: '18sp'
                halign: 'left'
                valign: 'middle'
                text_size: self.width, None
                size_hint_y: None
                height: 50

        BoxLayout:
            size_hint_y: 0.5


        Button:
            text: "Zurück zum Hauptmenü"
            on_press: root.manager.current = 'main'
            size_hint_y: None
            height: 80
            font_size: '20sp'
